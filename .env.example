# ============================================
# Stock Data Intelligence Dashboard
# Environment Configuration
# ============================================

# ============================================
# Database Configuration
# ============================================
# For PostgreSQL (production):
DATABASE_URL=postgresql://admin:changeme@localhost:5432/stock_dashboard
# For SQLite (development):
# DATABASE_URL=sqlite:///./stock_dashboard.db

# Database password (used in docker-compose)
DB_PASSWORD=changeme

# Database Connection Pool Settings
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ============================================
# Redis Cache (Optional)
# ============================================
# Enable caching for improved API performance
CACHE_ENABLED=false
REDIS_URL=redis://localhost:6379/0

# ============================================
# External APIs
# ============================================
# Alpha Vantage API key (optional - for fallback data source)
# Get your free API key at: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=demo

# Enable yfinance as primary data source
YFINANCE_ENABLED=true

# ============================================
# Application Settings
# ============================================
# Environment: development, staging, production
ENVIRONMENT=development

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log file path (relative to application root)
LOG_FILE=app.log

# Enable debug mode (set to false in production)
DEBUG=false

# Secret key for session management and security
# IMPORTANT: Change this in production!
SECRET_KEY=your_secret_key_here_change_in_production

# ============================================
# CORS Configuration
# ============================================
# Allowed origins for CORS (comma-separated)
# Use '*' for development, specific domains for production
ALLOWED_ORIGINS=*

# ============================================
# Data Collection
# ============================================
# Cron format: minute hour day month day_of_week
# Default: Daily at 6 PM (18:00)
COLLECTION_SCHEDULE=0 18 * * *

# Maximum concurrent API requests during data collection
MAX_CONCURRENT_REQUESTS=10

# Stock symbols to collect (comma-separated)
# Indian stocks example:
STOCK_SYMBOLS=RELIANCE.NS,TCS.NS,INFY.NS,HDFCBANK.NS,ICICIBANK.NS

# ============================================
# Machine Learning (Optional)
# ============================================
# Enable ML-based price prediction
ML_ENABLED=false

# Cron format for weekly model retraining (Sunday at midnight)
MODEL_RETRAIN_SCHEDULE=0 0 * * 0

# ML model storage path
MODEL_PATH=./models

# ============================================
# API Server
# ============================================
# Server host (0.0.0.0 for all interfaces)
HOST=0.0.0.0

# Server port
PORT=8000

# Number of Gunicorn worker processes
WORKERS=4

# Worker class (use uvicorn.workers.UvicornWorker for async support)
WORKER_CLASS=uvicorn.workers.UvicornWorker

# Request timeout in seconds
TIMEOUT=60

# ============================================
# Docker Compose Settings
# ============================================
# These are used by docker-compose.yml

# PostgreSQL settings
POSTGRES_DB=stock_dashboard
POSTGRES_USER=admin
POSTGRES_PASSWORD=changeme

# ============================================
# Deployment Platform Settings
# ============================================
# Render.com deployment
RENDER_EXTERNAL_URL=https://your-app.onrender.com

# Oracle Cloud deployment
OCI_REGION=us-ashburn-1
OCI_COMPARTMENT_ID=your_compartment_id

# ============================================
# Feature Flags
# ============================================
# Enable/disable optional features
ENABLE_TOP_GAINERS_LOSERS=true
ENABLE_STOCK_COMPARISON=true
ENABLE_PREDICTION=false
ENABLE_CSV_IMPORT=false
